# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://priyadharshini:Ezhilithanya@cluster0.crvutrr.mongodb.net/restaurant_db

# CORS – comma-separated allowed origins
# Add your Render frontend URL once deployed, e.g.:
# CORS_ORIGINS=http://localhost:5173,https://your-app.onrender.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seed endpoint secret (used by POST /api/admin/seed)
SEED_SECRET=change_this_to_something_secret
